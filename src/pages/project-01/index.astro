---
const lang = Astro.url.searchParams.get("lang") || "jp";

const texts = {
  jp: {
    title: "業務ログ可視化",
    subtitle: "タスク状態遷移をダッシュボードで可視化",
    back: "← ポートフォリオに戻る",
    stats: "統計",
    totalTasks: "総タスク数",
    completionRate: "完了率",
    avgLeadTime: "平均リードタイム",
    days: "日",
    stuckTasks: "滞留タスク",
    stuckDescription: "2 日以上停止中のタスク",
    noStuckTasks: "滞留中のタスクはありません",
    tasksByStatus: "ステータス別タスク一覧",
    title_col: "タイトル",
    status_col: "ステータス",
    leadTime_col: "リードタイム",
    dueDate_col: "期限",
    assignee_col: "担当者",
    loading: "読み込み中...",
    error: "エラーが発生しました",
  },
  en: {
    title: "Business Log Visualization",
    subtitle: "Visualize task state transitions on a dashboard",
    back: "← Back to Portfolio",
    stats: "Statistics",
    totalTasks: "Total Tasks",
    completionRate: "Completion Rate",
    avgLeadTime: "Avg Lead Time",
    days: "days",
    stuckTasks: "Stuck Tasks",
    stuckDescription: "Tasks stuck for 2+ days",
    noStuckTasks: "No stuck tasks",
    tasksByStatus: "Tasks by Status",
    title_col: "Title",
    status_col: "Status",
    leadTime_col: "Lead Time",
    dueDate_col: "Due Date",
    assignee_col: "Assignee",
    loading: "Loading...",
    error: "Error loading data",
  },
};

const t = texts[lang === "en" ? "en" : "jp"];
---

<html lang={lang === "en" ? "en" : "ja"}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{t.title} - yuki-labs</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        background: #fafafa;
        color: #333;
        line-height: 1.6;
      }
      nav {
        padding: 20px;
        text-align: right;
        border-bottom: 1px solid #ddd;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      nav a, nav button {
        margin: 0 10px;
        text-decoration: none;
        color: #0066cc;
        font-weight: 500;
        background: none;
        border: none;
        cursor: pointer;
      }
      nav a:hover, nav button:hover {
        text-decoration: underline;
      }
      .nav-left a {
        color: #666;
      }
      .nav-right {
        display: flex;
        gap: 10px;
      }
      header {
        padding: 40px 20px;
        text-align: center;
        background: white;
        border-bottom: 1px solid #ddd;
      }
      h1 {
        font-size: 2em;
        margin-bottom: 10px;
        color: #000;
      }
      header p {
        font-size: 1.1em;
        color: #666;
      }
      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 40px 20px;
      }
      .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
        margin-bottom: 40px;
      }
      .stat-card {
        background: white;
        border-radius: 8px;
        padding: 30px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        text-align: center;
      }
      .stat-label {
        font-size: 0.9em;
        color: #999;
        margin-bottom: 10px;
        text-transform: uppercase;
      }
      .stat-value {
        font-size: 2.5em;
        font-weight: bold;
        color: #0066cc;
      }
      .stat-unit {
        font-size: 0.9em;
        color: #999;
        margin-left: 5px;
      }
      section {
        margin-bottom: 40px;
      }
      h2 {
        font-size: 1.5em;
        margin-bottom: 10px;
        color: #000;
      }
      .section-desc {
        color: #666;
        margin-bottom: 20px;
        font-size: 0.95em;
      }
      .task-list, .stuck-list {
        background: white;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        overflow: hidden;
      }
      table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.95em;
      }
      thead {
        background: #f5f5f5;
        border-bottom: 2px solid #ddd;
      }
      th {
        padding: 15px;
        text-align: left;
        font-weight: 600;
        color: #333;
      }
      td {
        padding: 15px;
        border-bottom: 1px solid #eee;
      }
      tbody tr:last-child td {
        border-bottom: none;
      }
      tbody tr:hover {
        background: #f9f9f9;
      }
      .status-badge {
        display: inline-block;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.85em;
        font-weight: 500;
      }
      .status-pending {
        background: #fff3cd;
        color: #856404;
      }
      .status-in-progress {
        background: #d1ecf1;
        color: #0c5460;
      }
      .status-completed {
        background: #d4edda;
        color: #155724;
      }
      .status-archived {
        background: #e2e3e5;
        color: #383d41;
      }
      .empty-state {
        padding: 40px;
        text-align: center;
        color: #999;
      }
      .loading {
        padding: 40px;
        text-align: center;
        color: #666;
      }
      .error {
        padding: 20px;
        background: #f8d7da;
        color: #721c24;
        border-radius: 8px;
        margin-bottom: 20px;
      }
      .status-group {
        margin-bottom: 30px;
      }
      .status-group h3 {
        font-size: 1.1em;
        margin-bottom: 15px;
        padding-bottom: 10px;
        border-bottom: 2px solid #0066cc;
        color: #0066cc;
      }
    </style>
  </head>
  <body>
    <nav>
      <div class="nav-left">
        <a href="/?lang={lang}">{t.back}</a>
      </div>
      <div class="nav-right">
        <a href="?lang=jp">JP</a> |
        <a href="?lang=en">EN</a>
      </div>
    </nav>

    <header>
      <h1>{t.title}</h1>
      <p>{t.subtitle}</p>
    </header>

    <div class="container">
      <div id="content">
        <div class="loading">{t.loading}</div>
      </div>
    </div>

    <script define:vars={{ lang, t }}>
      import { createClient } from "@supabase/supabase-js";

      const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL;
      const SUPABASE_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

      const supabase = createClient(SUPABASE_URL, SUPABASE_KEY);

      async function loadDashboard() {
        try {
          const { data: tasks, error: tasksError } = await supabase
            .from("tasks")
            .select("*, task_statuses(name, code, is_terminal, color)")
            .eq("is_deleted", false)
            .order("created_at", { ascending: false });

          if (tasksError) throw tasksError;

          const { data: statuses, error: statusError } = await supabase
            .from("task_statuses")
            .select("*")
            .order("sort_order");

          if (statusError) throw statusError;

          renderDashboard(tasks, statuses);
        } catch (error) {
          const contentDiv = document.getElementById("content");
          contentDiv.innerHTML = `<div class="error">${t.error}: ${error.message}</div>`;
        }
      }

      function renderDashboard(tasks, statuses) {
        const contentDiv = document.getElementById("content");

        // Calculate stats
        const completedTasks = tasks.filter(t => t.task_statuses?.is_terminal);
        const completionRate = tasks.length > 0
          ? Math.round((completedTasks.length / tasks.length) * 100)
          : 0;

        const leadTimes = completedTasks
          .filter(t => t.created_at && t.closed_at)
          .map(t => {
            const created = new Date(t.created_at);
            const closed = new Date(t.closed_at);
            return (closed - created) / (1000 * 60 * 60 * 24);
          });

        const avgLeadTime = leadTimes.length > 0
          ? (leadTimes.reduce((a, b) => a + b, 0) / leadTimes.length).toFixed(1)
          : 0;

        // Find stuck tasks (non-terminal, updated > 2 days ago)
        const twoDaysAgo = new Date(Date.now() - 2 * 24 * 60 * 60 * 1000);
        const stuckTasks = tasks.filter(t =>
          !t.task_statuses?.is_terminal &&
          new Date(t.updated_at) < twoDaysAgo
        );

        let html = `
          <div class="stats-grid">
            <div class="stat-card">
              <div class="stat-label">${t.totalTasks}</div>
              <div class="stat-value">${tasks.length}</div>
            </div>
            <div class="stat-card">
              <div class="stat-label">${t.completionRate}</div>
              <div class="stat-value">${completionRate}<span class="stat-unit">%</span></div>
            </div>
            <div class="stat-card">
              <div class="stat-label">${t.avgLeadTime}</div>
              <div class="stat-value">${avgLeadTime}<span class="stat-unit">${t.days}</span></div>
            </div>
          </div>
        `;

        // Stuck tasks section
        html += `
          <section>
            <h2>${t.stuckTasks}</h2>
            <p class="section-desc">${t.stuckDescription}</p>
        `;

        if (stuckTasks.length === 0) {
          html += `<div class="empty-state">${t.noStuckTasks}</div>`;
        } else {
          html += `
            <div class="stuck-list">
              <table>
                <thead>
                  <tr>
                    <th>${t.title_col}</th>
                    <th>${t.status_col}</th>
                    <th>${t.dueDate_col}</th>
                    <th>${t.assignee_col}</th>
                  </tr>
                </thead>
                <tbody>
          `;
          stuckTasks.forEach(task => {
            const statusBadge = getStatusBadge(task.task_statuses?.code);
            const dueDate = task.due_date ? new Date(task.due_date).toLocaleDateString() : "-";
            html += `
              <tr>
                <td>${task.title}</td>
                <td><span class="status-badge ${statusBadge}">${task.task_statuses?.name || "Unknown"}</span></td>
                <td>${dueDate}</td>
                <td>${task.assigned_to || "-"}</td>
              </tr>
            `;
          });
          html += `
                </tbody>
              </table>
            </div>
          `;
        }
        html += `</section>`;

        // Tasks by status
        html += `
          <section>
            <h2>${t.tasksByStatus}</h2>
        `;

        statuses.forEach(status => {
          const statusTasks = tasks.filter(t => t.current_status_id === status.id);
          html += `
            <div class="status-group">
              <h3>${status.name} (${statusTasks.length})</h3>
          `;

          if (statusTasks.length === 0) {
            html += `<div class="empty-state">${t.noStuckTasks}</div>`;
          } else {
            html += `
              <div class="task-list">
                <table>
                  <thead>
                    <tr>
                      <th>${t.title_col}</th>
                      <th>${t.leadTime_col}</th>
                      <th>${t.dueDate_col}</th>
                      <th>${t.assignee_col}</th>
                    </tr>
                  </thead>
                  <tbody>
            `;
            statusTasks.forEach(task => {
              const leadTime = calculateLeadTime(task);
              const dueDate = task.due_date ? new Date(task.due_date).toLocaleDateString() : "-";
              html += `
                <tr>
                  <td>${task.title}</td>
                  <td>${leadTime}</td>
                  <td>${dueDate}</td>
                  <td>${task.assigned_to || "-"}</td>
                </tr>
              `;
            });
            html += `
                  </tbody>
                </table>
              </div>
            `;
          }
          html += `</div>`;
        });

        html += `</section>`;
        contentDiv.innerHTML = html;
      }

      function calculateLeadTime(task) {
        if (!task.created_at || !task.closed_at) return "-";
        const created = new Date(task.created_at);
        const closed = new Date(task.closed_at);
        const days = Math.round((closed - created) / (1000 * 60 * 60 * 24));
        return `${days} ${t.days}`;
      }

      function getStatusBadge(code) {
        const badges = {
          "pending": "status-pending",
          "in-progress": "status-in-progress",
          "completed": "status-completed",
          "archived": "status-archived",
        };
        return badges[code] || "status-pending";
      }

      loadDashboard();
    </script>
  </body>
</html>
