---
const lang = Astro.url.searchParams.get("lang") || "jp";

const texts = {
  jp: {
    title: "検索AI / Knowledge DB",
    subtitle: "ベクトル検索による知識検索システム",
    back: "← ポートフォリオに戻る",
    tech: "技術スタック",
    features: "機能",
    demo: "デモアプリ",
    demoLink: "https://knowledge-db-web.netlify.app",
    github: "→ GitHub",
  },
  en: {
    title: "Search AI / Knowledge DB",
    subtitle: "Knowledge search system with vector search",
    back: "← Back to Portfolio",
    tech: "Tech Stack",
    features: "Features",
    demo: "Demo App",
    demoLink: "https://knowledge-db-web.netlify.app",
    github: "→ GitHub",
  },
};

const t = texts[lang === "en" ? "en" : "jp"];
---

<html lang={lang === "en" ? "en" : "ja"}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{t.title} - yuki-labs</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        background: #fafafa;
        color: #333;
        line-height: 1.6;
      }
      nav {
        padding: 20px;
        text-align: right;
        border-bottom: 1px solid #ddd;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      nav a {
        margin: 0 10px;
        text-decoration: none;
        color: #0066cc;
        font-weight: 500;
      }
      nav a:hover {
        text-decoration: underline;
      }
      .nav-left a {
        color: #666;
      }
      .nav-right {
        display: flex;
        gap: 10px;
      }
      header {
        padding: 40px 20px;
        text-align: center;
        background: white;
        border-bottom: 1px solid #ddd;
      }
      h1 {
        font-size: 2em;
        margin-bottom: 10px;
        color: #000;
      }
      header p {
        font-size: 1.1em;
        color: #666;
      }
      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 40px 20px;
      }
      section {
        margin-bottom: 40px;
      }
      h2 {
        font-size: 1.5em;
        margin-bottom: 20px;
        color: #000;
        border-bottom: 2px solid #0066cc;
        padding-bottom: 10px;
      }
      .tech-items {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin-bottom: 20px;
      }
      .tech-item {
        background: white;
        padding: 20px;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
      }
      .tech-item strong {
        display: block;
        color: #0066cc;
        margin-bottom: 5px;
      }
      .features-list {
        background: white;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        padding: 20px;
        margin-bottom: 20px;
      }
      .features-list ul {
        list-style: none;
        padding-left: 0;
      }
      .features-list li {
        padding: 10px 0;
        padding-left: 30px;
        position: relative;
      }
      .features-list li::before {
        content: "✓";
        position: absolute;
        left: 0;
        color: #0066cc;
        font-weight: bold;
      }
      .links {
        display: flex;
        gap: 20px;
        flex-wrap: wrap;
        margin-top: 30px;
      }
      .link-btn {
        display: inline-block;
        padding: 12px 24px;
        background: #0066cc;
        color: white;
        text-decoration: none;
        border-radius: 8px;
        font-weight: 500;
      }
      .link-btn:hover {
        background: #0052a3;
      }
      .link-btn.secondary {
        background: #666;
      }
      .link-btn.secondary:hover {
        background: #333;
      }
      .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
        margin-bottom: 40px;
      }
      .stat-card {
        background: white;
        border-radius: 8px;
        padding: 30px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        text-align: center;
      }
      .stat-label {
        font-size: 0.9em;
        color: #999;
        margin-bottom: 10px;
        text-transform: uppercase;
      }
      .stat-value {
        font-size: 2.5em;
        font-weight: bold;
        color: #0066cc;
      }
      .stat-unit {
        font-size: 0.9em;
        color: #999;
        margin-left: 5px;
      }
    </style>
  </head>
  <body>
    <nav>
      <div class="nav-left">
        <a href="/?lang={lang}">{t.back}</a>
      </div>
      <div class="nav-right">
        <a href="?lang=jp">JP</a> |
        <a href="?lang=en">EN</a>
      </div>
    </nav>

    <header>
      <h1>{t.title}</h1>
      <p>{t.subtitle}</p>
    </header>

    <div class="container">
      <div class="stats-grid">
        <div class="stat-card">
          <div class="stat-label">{lang === "en" ? "Response Time" : "応答時間"}</div>
          <div class="stat-value">{"< 100"}<span class="stat-unit">ms</span></div>
        </div>
        <div class="stat-card">
          <div class="stat-label">{lang === "en" ? "Search Type" : "検索タイプ"}</div>
          <div class="stat-value" style="font-size: 1.5em;">Vector + FTS</div>
        </div>
        <div class="stat-card">
          <div class="stat-label">{lang === "en" ? "Database" : "データベース"}</div>
          <div class="stat-value" style="font-size: 1.5em;">Neon PG</div>
        </div>
      </div>

      <section>
        <h2>{t.tech}</h2>
        <div class="tech-items">
          <div class="tech-item">
            <strong>Next.js 16</strong>
            React フロントエンド
          </div>
          <div class="tech-item">
            <strong>Neon PostgreSQL</strong>
            pgvector サポート
          </div>
          <div class="tech-item">
            <strong>Full Text Search</strong>
            高速全文検索
          </div>
          <div class="tech-item">
            <strong>Netlify</strong>
            ホスティング
          </div>
        </div>
      </section>

      <section>
        <h2>{t.features}</h2>
        <div class="features-list">
          <ul>
            <li>{lang === "en" ? "Vector search using pgvector embeddings" : "pgvector ベクトル検索"}</li>
            <li>{lang === "en" ? "Full Text Search for keyword matching" : "全文検索（キーワードマッチング）"}</li>
            <li>{lang === "en" ? "Sub-100ms response time for instant results" : "100ms以下の超高速応答"}</li>
            <li>{lang === "en" ? "Responsive design for all devices" : "レスポンシブデザイン"}</li>
            <li>{lang === "en" ? "Real-time knowledge base updates" : "リアルタイム知識ベース更新"}</li>
          </ul>
        </div>
      </section>

      <section>
        <div class="links">
          <a href={t.demoLink} target="_blank" rel="noopener noreferrer" class="link-btn">{t.demo}</a>
          <a href="https://github.com/yukilabs-core/knowledge-db-web" target="_blank" rel="noopener noreferrer" class="link-btn secondary">{t.github}</a>
        </div>
      </section>
    </div>
  </body>
</html>
