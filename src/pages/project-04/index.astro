---
const lang = Astro.url.searchParams.get("lang") || "jp";

const texts = {
  jp: {
    title: "業務データ分析",
    subtitle: "500件の業務ログから KPI 自動計算、ボトルネック検出",
    back: "← ポートフォリオに戻る",
    tech: "技術スタック",
    features: "機能",
    report: "分析レポート",
    github: "→ GitHub",
  },
  en: {
    title: "Business Data Analysis",
    subtitle: "Auto-generate KPIs, detect bottlenecks, and suggest improvements from 500 task records",
    back: "← Back to Portfolio",
    tech: "Tech Stack",
    features: "Features",
    report: "Analysis Report",
    github: "→ GitHub",
  },
};

const t = texts[lang === "en" ? "en" : "jp"];
---

<html lang={lang === "en" ? "en" : "ja"}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{t.title} - yuki-labs</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        background: #fafafa;
        color: #333;
        line-height: 1.6;
      }
      nav {
        padding: 20px;
        text-align: right;
        border-bottom: 1px solid #ddd;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      nav a {
        margin: 0 10px;
        text-decoration: none;
        color: #0066cc;
        font-weight: 500;
      }
      nav a:hover {
        text-decoration: underline;
      }
      .nav-left a {
        color: #666;
      }
      .nav-right {
        display: flex;
        gap: 10px;
      }
      header {
        padding: 40px 20px;
        text-align: center;
        background: white;
        border-bottom: 1px solid #ddd;
      }
      h1 {
        font-size: 2em;
        margin-bottom: 10px;
        color: #000;
      }
      header p {
        font-size: 1.1em;
        color: #666;
      }
      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 40px 20px;
      }
      section {
        margin-bottom: 40px;
      }
      h2 {
        font-size: 1.5em;
        margin-bottom: 20px;
        color: #000;
        border-bottom: 2px solid #0066cc;
        padding-bottom: 10px;
      }
      .tech-items {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin-bottom: 20px;
      }
      .tech-item {
        background: white;
        padding: 20px;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
      }
      .tech-item strong {
        display: block;
        color: #0066cc;
        margin-bottom: 5px;
      }
      .features-list {
        background: white;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        padding: 20px;
        margin-bottom: 20px;
      }
      .features-list ul {
        list-style: none;
        padding-left: 0;
      }
      .features-list li {
        padding: 10px 0;
        padding-left: 30px;
        position: relative;
      }
      .features-list li::before {
        content: "✓";
        position: absolute;
        left: 0;
        color: #0066cc;
        font-weight: bold;
      }
      .report-container {
        background: white;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        overflow: hidden;
        margin-bottom: 20px;
      }
      iframe {
        width: 100%;
        height: 800px;
        border: none;
      }
      .links {
        display: flex;
        gap: 20px;
        margin-top: 30px;
      }
      .link-btn {
        display: inline-block;
        padding: 12px 24px;
        background: #0066cc;
        color: white;
        text-decoration: none;
        border-radius: 8px;
        font-weight: 500;
      }
      .link-btn:hover {
        background: #0052a3;
      }
      .link-btn.secondary {
        background: #666;
      }
      .link-btn.secondary:hover {
        background: #333;
      }
    </style>
  </head>
  <body>
    <nav>
      <div class="nav-left">
        <a href="/?lang={lang}">{t.back}</a>
      </div>
      <div class="nav-right">
        <a href="?lang=jp">JP</a> |
        <a href="?lang=en">EN</a>
      </div>
    </nav>

    <header>
      <h1>{t.title}</h1>
      <p>{t.subtitle}</p>
    </header>

    <div class="container">
      <section>
        <h2>{t.tech}</h2>
        <div class="tech-items">
          <div class="tech-item">
            <strong>Python</strong>
            データ分析エンジン
          </div>
          <div class="tech-item">
            <strong>Pandas</strong>
            データ処理・集計
          </div>
          <div class="tech-item">
            <strong>Matplotlib</strong>
            グラフ可視化
          </div>
          <div class="tech-item">
            <strong>pytest</strong>
            テスト自動化
          </div>
        </div>
      </section>

      <section>
        <h2>{t.features}</h2>
        <div class="features-list">
          <ul>
            <li>{lang === "en" ? "Auto-calculate KPIs (completion rate, average processing time, SLA compliance)" : "KPI 自動計算（完了率、平均処理時間、SLA超過率など）"}</li>
            <li>{lang === "en" ? "Detect bottleneck processes and workflow stages" : "ボトルネック工程の自動検出"}</li>
            <li>{lang === "en" ? "Per-assignee capability and workload analysis" : "担当者別の能力・負荷分析"}</li>
            <li>{lang === "en" ? "AI-powered improvement suggestions" : "AI 改善提案の自動生成"}</li>
            <li>{lang === "en" ? "Visual graphs and comprehensive reports" : "グラフ・レポートの自動出力"}</li>
          </ul>
        </div>
      </section>

      <section>
        <h2>{t.report}</h2>
        <div class="report-container">
          <iframe src="/project-04/report/index.html" title="Analysis Report"></iframe>
        </div>
      </section>

      <section>
        <div class="links">
          <a href="https://github.com/yukilabs-core/operational-analytics-system" target="_blank" rel="noopener noreferrer" class="link-btn">{t.github}</a>
        </div>
      </section>
    </div>
  </body>
</html>
