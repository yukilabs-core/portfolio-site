---
const lang = Astro.url.searchParams.get("lang") || "jp";

const texts = {
  jp: {
    title: "判断ログシステム",
    subtitle: "意思決定を構造化して記録・管理・分析。無料クラウドスタック",
    back: "← ポートフォリオに戻る",
    tech: "技術スタック",
    features: "機能",
    github: "→ GitHub",
  },
  en: {
    title: "Decision Log System",
    subtitle: "Record, manage and analyze decision-making with structured templates. Free cloud stack.",
    back: "← Back to Portfolio",
    tech: "Tech Stack",
    features: "Features",
    github: "→ GitHub",
  },
};

const t = texts[lang === "en" ? "en" : "jp"];
---

<html lang={lang === "en" ? "en" : "ja"}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{t.title} - yuki-labs</title>
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        background: #fafafa;
        color: #333;
        line-height: 1.6;
      }
      nav {
        padding: 20px;
        text-align: right;
        border-bottom: 1px solid #ddd;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
      nav a {
        margin: 0 10px;
        text-decoration: none;
        color: #0066cc;
        font-weight: 500;
      }
      nav a:hover {
        text-decoration: underline;
      }
      .nav-left a {
        color: #666;
      }
      .nav-right {
        display: flex;
        gap: 10px;
      }
      header {
        padding: 40px 20px;
        text-align: center;
        background: white;
        border-bottom: 1px solid #ddd;
      }
      h1 {
        font-size: 2em;
        margin-bottom: 10px;
        color: #000;
      }
      header p {
        font-size: 1.1em;
        color: #666;
      }
      .container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 40px 20px;
      }
      section {
        margin-bottom: 40px;
      }
      h2 {
        font-size: 1.5em;
        margin-bottom: 20px;
        color: #000;
        border-bottom: 2px solid #0066cc;
        padding-bottom: 10px;
      }
      .tech-items {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
        margin-bottom: 20px;
      }
      .tech-item {
        background: white;
        padding: 20px;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
      }
      .tech-item strong {
        display: block;
        color: #0066cc;
        margin-bottom: 5px;
      }
      .features-list {
        background: white;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        padding: 20px;
        margin-bottom: 20px;
      }
      .features-list ul {
        list-style: none;
        padding-left: 0;
      }
      .features-list li {
        padding: 10px 0;
        padding-left: 30px;
        position: relative;
      }
      .features-list li::before {
        content: "✓";
        position: absolute;
        left: 0;
        color: #0066cc;
        font-weight: bold;
      }
      .highlights {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
        margin-bottom: 40px;
      }
      .highlight-card {
        background: white;
        padding: 25px;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        border-left: 4px solid #0066cc;
      }
      .highlight-card h3 {
        color: #0066cc;
        margin-bottom: 10px;
        font-size: 1.1em;
      }
      .links {
        display: flex;
        gap: 20px;
        margin-top: 30px;
      }
      .link-btn {
        display: inline-block;
        padding: 12px 24px;
        background: #0066cc;
        color: white;
        text-decoration: none;
        border-radius: 8px;
        font-weight: 500;
      }
      .link-btn:hover {
        background: #0052a3;
      }
    </style>
  </head>
  <body>
    <nav>
      <div class="nav-left">
        <a href="/?lang={lang}">{t.back}</a>
      </div>
      <div class="nav-right">
        <a href="?lang=jp">JP</a> |
        <a href="?lang=en">EN</a>
      </div>
    </nav>

    <header>
      <h1>{t.title}</h1>
      <p>{t.subtitle}</p>
    </header>

    <div class="container">
      <section>
        <h2>{t.tech}</h2>
        <div class="tech-items">
          <div class="tech-item">
            <strong>Next.js 16</strong>
            React フロントエンド
          </div>
          <div class="tech-item">
            <strong>Supabase</strong>
            PostgreSQL バックエンド
          </div>
          <div class="tech-item">
            <strong>Zustand</strong>
            状態管理
          </div>
          <div class="tech-item">
            <strong>Netlify</strong>
            ホスティング
          </div>
        </div>
      </section>

      <section>
        <h2>{lang === "en" ? "Highlights" : "特徴"}</h2>
        <div class="highlights">
          <div class="highlight-card">
            <h3>{lang === "en" ? "Structured Templates" : "構造化テンプレート"}</h3>
            <p>{lang === "en" ? "Record decisions with context, alternatives, and reasoning" : "背景、選択肢、理由を構造化して記録"}</p>
          </div>
          <div class="highlight-card">
            <h3>{lang === "en" ? "Compare Options" : "選択肢比較"}</h3>
            <p>{lang === "en" ? "Weigh pros/cons and make informed choices" : "複数の選択肢をメリット・デメリットで比較"}</p>
          </div>
          <div class="highlight-card">
            <h3>{lang === "en" ? "Learn from Past" : "過去から学ぶ"}</h3>
            <p>{lang === "en" ? "Review outcomes and improve future decisions" : "結果を振り返り、次の判断に活かす"}</p>
          </div>
          <div class="highlight-card">
            <h3>{lang === "en" ? "Search & Analyze" : "検索・分析"}</h3>
            <p>{lang === "en" ? "Find similar past decisions and identify patterns" : "類似の判断を検索してパターンを認識"}</p>
          </div>
          <div class="highlight-card">
            <h3>{lang === "en" ? "Free Cloud Stack" : "無料クラウド"}</h3>
            <p>{lang === "en" ? "Netlify + Supabase with zero monthly cost" : "Netlify + Supabase で無料ホスティング"}</p>
          </div>
          <div class="highlight-card">
            <h3>{lang === "en" ? "Real-time Sync" : "リアルタイム同期"}</h3>
            <p>{lang === "en" ? "Changes sync instantly across all devices" : "複数端末でリアルタイムに同期"}</p>
          </div>
        </div>
      </section>

      <section>
        <h2>{t.features}</h2>
        <div class="features-list">
          <ul>
            <li>{lang === "en" ? "Create and categorize decision logs with rich metadata" : "意思決定をカテゴリー・タグで分類・管理"}</li>
            <li>{lang === "en" ? "Compare multiple alternatives with weighted scoring" : "複数選択肢をスコアリングして比較"}</li>
            <li>{lang === "en" ? "Track decision outcomes and lessons learned" : "判断の結果と学びを記録・追跡"}</li>
            <li>{lang === "en" ? "Full-text search across all decision logs" : "全判断ログを対象とした全文検索"}</li>
            <li>{lang === "en" ? "Responsive design works on mobile and desktop" : "モバイル・デスクトップ両対応"}</li>
          </ul>
        </div>
      </section>

      <section>
        <div class="links">
          <a href="https://github.com/yukilabs-core/decision-log-system" target="_blank" rel="noopener noreferrer" class="link-btn">{t.github}</a>
        </div>
      </section>
    </div>
  </body>
</html>
